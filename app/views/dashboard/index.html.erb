<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Click Connect · internal skills & projects</title>
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

</head>
<body>
  <div class="app-container">

    <!-- Top Bar -->
    <div class="top-bar">
      <div class="user-badge">
        <i class="fas fa-circle-user"></i>
        <span>
          <strong>Welcome, <%= @user.first_name %></strong>
        </span>
      </div>
    </div>

    <!-- Main 3-Column Grid -->
    <div class="main-grid">

      <!-- My Skills -->
      <div class="card">
        <div class="card-title">My Skills</div>
        <div class="skills-wrap">
          <span class="skill-tag tag-orange">Networking</span>
          <span class="skill-tag tag-green">Problem Solving</span>
          <span class="skill-tag tag-purple">Ruby</span>
          <span class="skill-tag tag-blue">C++</span>
          <span class="skill-tag tag-gray">GitHub</span>
          <span class="skill-tag tag-gray">Self-motivated</span>
        </div>
        <div class="skill-bar-wrap" style="margin-top: 16px;">
          <div class="skill-bar-row">
            <span class="skill-bar-label">Networking</span>
            <div class="skill-bar-track">
              <div class="skill-bar-fill" style="width: 85%;"></div>
            </div>
          </div>
          <div class="skill-bar-row">
            <span class="skill-bar-label">Ruby</span>
            <div class="skill-bar-track">
              <div class="skill-bar-fill" style="width: 70%; background: #7c4fa0;"></div>
            </div>
          </div>
          <div class="skill-bar-row">
            <span class="skill-bar-label">C++</span>
            <div class="skill-bar-track">
              <div class="skill-bar-fill" style="width: 55%; background: #2a5ca8;"></div>
            </div>
          </div>
          <div class="skill-bar-row">
            <span class="skill-bar-label">GitHub</span>
            <div class="skill-bar-track">
              <div class="skill-bar-fill" style="width: 90%; background: #2a6b5c;"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- My Projects -->
      <div class="card">
        <div class="card-title">My Projects</div>
        <div style="display: flex; flex-direction: column; gap: 10px;">

          <div style="display: flex; align-items: center; gap: 12px; padding: 8px; background: var(--surface2); border-radius: 8px;">
            <div style="text-align: center; min-width: 36px;">
              <div style="font-size: 0.6rem; text-transform: uppercase; color: var(--ink2);">Mar</div>
              <div style="font-size: 1.1rem; font-weight: 600; line-height: 1;">02</div>
            </div>
            <div>
              <div style="font-size: 0.82rem; font-weight: 500;">OpenBridge v2 Sprint</div>
              <div style="font-size: 0.72rem; color: var(--ink2);">5 days left · Backend task</div>
            </div>
          </div>

          <div style="display: flex; align-items: center; gap: 12px; padding: 8px; border-radius: 8px;">
            <div style="text-align: center; min-width: 36px;">
              <div style="font-size: 0.6rem; text-transform: uppercase; color: var(--ink2);">Mar</div>
              <div style="font-size: 1.1rem; font-weight: 600; line-height: 1;">10</div>
            </div>
            <div>
              <div style="font-size: 0.82rem; font-weight: 500;">Portfolio Review</div>
              <div style="font-size: 0.72rem; color: var(--ink2);">13 days left · All members</div>
            </div>
          </div>

          <div style="display: flex; align-items: center; gap: 12px; padding: 8px; border-radius: 8px;">
            <div style="text-align: center; min-width: 36px;">
              <div style="font-size: 0.6rem; text-transform: uppercase; color: var(--ink2);">Mar</div>
              <div style="font-size: 1.1rem; font-weight: 600; line-height: 1;">18</div>
            </div>
            <div>
              <div style="font-size: 0.82rem; font-weight: 500;">Team Check-in Meeting</div>
              <div style="font-size: 0.72rem; color: var(--ink2);">21 days left · Virtual</div>
            </div>
          </div>

        </div>
      </div>

      <!-- Recent Activity -->
      <div class="card">
        <div class="card-title">Recent Activity</div>
        <div class="activity-item">
          <div class="activity-dot" style="background: #c8460a;"></div>
          <div>
            <div class="activity-text"><strong>You</strong> joined project <strong>OpenBridge v2</strong></div>
            <div class="activity-time">2 hours ago</div>
          </div>
        </div>
        <div class="activity-item">
          <div class="activity-dot" style="background: #2a6b5c;"></div>
          <div>
            <div class="activity-text"><strong>James Brown</strong> connected with you</div>
            <div class="activity-time">Yesterday at 4:12 PM</div>
          </div>
        </div>
        <div class="activity-item">
          <div class="activity-dot" style="background: #7c4fa0;"></div>
          <div>
            <div class="activity-text"><strong>You</strong> added skill <strong>C++</strong></div>
            <div class="activity-time">2 days ago</div>
          </div>
        </div>
        <div class="activity-item">
          <div class="activity-dot" style="background: #2a5ca8;"></div>
          <div>
            <div class="activity-text"><strong>Sara Ming</strong> commented on <strong>your profile</strong></div>
            <div class="activity-time">3 days ago</div>
          </div>
        </div>
        <div class="activity-item">
          <div class="activity-dot" style="background: #888;"></div>
          <div>
            <div class="activity-text"><strong>You</strong> completed profile setup</div>
            <div class="activity-time">Feb 20</div>
          </div>
        </div>
      </div>

    </div><!-- /.main-grid -->
  </div><!-- /.app-container -->
</body>
</html>
