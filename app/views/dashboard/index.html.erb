<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Click Connect · internal skills & projects</title>
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

</head>
<body>
  <div class="app-container">

    <!-- Top Bar -->
    <div class="top-bar">
      <div class="user-badge">
        <i class="fas fa-circle-user"></i>
        <span>
          <strong>Welcome, <%= @user.first_name %></strong>
        </span>
      </div>
    </div>

    <!-- Main 3-Column Grid -->
    <div class="main-grid">

  <!-- My Skills -->
<div class="card">
  <div class="card-title">My Skills</div>

  <% if @skills.any? %>
    <!-- Skill Tags -->
    <div class="skills-wrap">
      <% tag_colors = ["tag-orange", "tag-green", "tag-purple", "tag-blue", "tag-gray"] %>
      <% @skills.each_with_index do |skill, index| %>
        <span class="skill-tag <%= tag_colors[index % tag_colors.length] %>">
          <%= skill.name.titleize %>
        </span>
      <% end %>
    </div>

    <!-- Skill Bars -->
    <% bar_colors = ["#c8460a", "#7c4fa0", "#2a5ca8", "#2a6b5c", "#888"] %>
    <div class="skill-bar-wrap" style="margin-top: 16px;">
      <% @skills.first(5).each_with_index do |skill, index| %>
        <div class="skill-bar-row">
          <span class="skill-bar-label"><%= skill.name.titleize %></span>
          <div class="skill-bar-track">
            <div class="skill-bar-fill" style="width: <%= [45, 55, 70, 80, 90][index % 5] %>%; background: <%= bar_colors[index % bar_colors.length] %>;"></div>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <div style="font-size: 0.85rem; color: #888; text-align: center; padding: 20px 0;">
      No skills yet — <%= link_to "add some", edit_user_registration_path %>!
    </div>
  <% end %>

</div>

      <!-- My Projects -->
<div class="card">
  <div class="card-title"> All Projects</div>
  <div style="display: flex; flex-direction: column; gap: 10px;">

    <% if @projects.any? %>
      <% @projects.first(5).each do |project| %>
        <div style="display: flex; align-items: center; gap: 12px; padding: 8px; background: var(--surface2); border-radius: 8px;">
          <div style="text-align: center; min-width: 36px;">
            <div style="font-size: 0.6rem; text-transform: uppercase; color: var(--ink2);">
              <%= project.created_at.strftime("%b") %>
            </div>
            <div style="font-size: 1.1rem; font-weight: 600; line-height: 1;">
              <%= project.created_at.strftime("%d") %>
            </div>
          </div>
          <div>
            <div style="font-size: 0.82rem; font-weight: 500;">
              <%= link_to project.title, project, style: "text-decoration: none; color: inherit;" %>
            </div>
            <div style="font-size: 0.72rem; color: var(--ink2);">
              <%= truncate(project.description, length: 40) %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div style="font-size: 0.85rem; color: #888; text-align: center; padding: 20px 0;">
        No projects yet — <%= link_to "add one", new_project_path %>!
      </div>
    <% end %>

  </div>
</div>

     <!-- Recent Activity -->
<div class="card">
  <div class="card-title">Recent Activity</div>

  <% @recent_users.each do |user| %>
    <div class="activity-item">
      <div class="activity-dot" style="background: #2a6b5c;"></div>
      <div>
        <div class="activity-text"><strong><%= user.full_name %></strong> joined Click Connect</div>
        <div class="activity-time"><%= time_ago_in_words(user.created_at) %> ago</div>
      </div>
    </div>
  <% end %>

  <% @recent_projects.each do |project| %>
    <div class="activity-item">
      <div class="activity-dot" style="background: #c8460a;"></div>
      <div>
        <div class="activity-text"><strong><%= project.title %></strong> was added</div>
        <div class="activity-time"><%= time_ago_in_words(project.created_at) %> ago</div>
      </div>
    </div>
  <% end %>

</div>

    </div><!-- /.main-grid -->
  </div><!-- /.app-container -->
</body>
</html>
