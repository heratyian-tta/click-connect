<p id="notice"><%= notice %></p>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Click Connect · internal skills & projects</title>
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background: #f2f6fb;
            color: #1a2b3e;
            line-height: 1.5;
            padding: 1.8rem 1.5rem;
        }

        .app-container {a
            max-width: 1400px;
            margin: 0 auto;
        }

        /* header */
        .top-bar {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.2rem;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-size: 1.9rem;
            font-weight: 600;
            color: #0f3b5e;
        }

        .logo i {
            color: #2b6c9e;
        }

        .user-badge {
            background: white;
            border-radius: 40px;
            padding: 0.5rem 1.5rem 0.5rem 1rem;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 4px 12px rgba(0,30,60,0.08);
        }

        .user-badge i {
            font-size: 1.8rem;
            color: #1f5f92;
        }

        /* main 3‑column grid */
        .dashboard {
            display: grid;
            grid-template-columns: 1.2fr 1.9fr 1.2fr;
            gap: 1.8rem;
            align-items: start;
        }

        /* universal card style */
        .card {
            background: white;
            border-radius: 2rem;
            padding: 1.6rem 1.5rem;
            box-shadow: 0 10px 28px -8px rgba(0,40,70,0.12);
            margin-bottom: 1.8rem;
        }

        .card-header {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 1.4rem;
            font-weight: 600;
            font-size: 1.2rem;
            color: #1d435e;
            border-bottom: 2px solid #e9f0f7;
            padding-bottom: 0.6rem;
        }

        .card-header i {
            color: #336fa3;
            width: 2rem;
        }

        /* search row */
        .search-box {
            display: flex;
            align-items: center;
            background: #f0f5fc;
            border-radius: 3rem;
            padding: 0.2rem 0.2rem 0.2rem 1.5rem;
            margin-bottom: 1.5rem;
        }

        .search-box i {
            color: #597faa;
        }

        .search-box input {
            border: none;
            background: transparent;
            padding: 0.8rem 0.6rem;
            width: 100%;
            outline: none;
            font-size: 0.95rem;
        }

        .search-box button {
            background: #1e4f8a;
            border: none;
            color: white;
            font-weight: 500;
            padding: 0.6rem 1.6rem;
            border-radius: 3rem;
            cursor: pointer;
            transition: 0.1s;
            white-space: nowrap;
        }

        .search-box button:hover {
            background: #123f6e;
        }

        /* skill chips & results */
        .skill-chip {
            background: #e4eefa;
            padding: 0.45rem 1.2rem;
            border-radius: 40px;
            font-size: 0.9rem;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin: 0.25rem;
            border: 1px solid #c5d9f0;
        }

        .person-result {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 0.9rem 0.5rem;
            border-bottom: 1px solid #e5eef9;
        }

        .person-result:last-child {
            border-bottom: none;
        }

        .result-avatar {
            width: 46px;
            height: 46px;
            background: linear-gradient(145deg, #4177b0, #1f4f82);
            border-radius: 40%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
        }

        .result-info h4 {
            font-size: 1rem;
            font-weight: 650;
        }

        .result-skills {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin-top: 4px;
        }

        .mini-skill {
            background: #d9e6f5;
            font-size: 0.7rem;
            padding: 0.2rem 0.7rem;
            border-radius: 30px;
        }

        /* editable skill list (my skills) */
        .my-skills-list {
            display: flex;
            flex-wrap: wrap;
            gap: 0.6rem;
            margin: 1rem 0 1.2rem;
        }

        .skill-item {
            background: #e1effb;
            padding: 0.4rem 1.2rem 0.4rem 1.4rem;
            border-radius: 40px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .skill-item i {
            color: #b22234; /* remove icon tone */
            cursor: pointer;
            opacity: 0.7;
            transition: 0.1s;
            font-size: 1rem;
        }

        .skill-item i:hover {
            opacity: 1;
            color: #c0392b;
        }

        .add-skill-form {
            display: flex;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        .add-skill-form input {
            flex: 1;
            padding: 0.7rem 1.2rem;
            border: 1px solid #cbdbe9;
            border-radius: 40px;
            outline: none;
            font-size: 0.9rem;
        }

        .add-skill-form button {
            background: #1e4f8a;
            border: none;
            color: white;
            padding: 0 1.6rem;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
        }

        /* project cards (editable) */
        .project-card {
            background: #f8fbfe;
            border-radius: 1.5rem;
            padding: 1.2rem 1.3rem;
            margin-bottom: 1.2rem;
            border: 1px solid #dae6f2;
        }

        .project-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.4rem;
        }

        .project-header h4 {
            font-size: 1.1rem;
            font-weight: 650;
        }

        .project-actions i {
            margin-left: 0.7rem;
            color: #6585a6;
            cursor: pointer;
            font-size: 1rem;
        }

        .project-actions i:hover {
            color: #1f4f82;
        }

        .project-meta {
            font-size: 0.8rem;
            color: #3e6a91;
            margin-bottom: 0.6rem;
            display: flex;
            gap: 1rem;
        }

        .project-desc {
            font-size: 0.9rem;
            color: #2d4b6b;
            margin: 0.6rem 0 0.8rem;
        }

        .project-skills {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        .project-skill-tag {
            background: #c9dff5;
            padding: 0.2rem 1rem;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .btn-add-project {
            background: white;
            border: 2px dashed #769dc0;
            color: #1f4a74;
            padding: 0.9rem;
            border-radius: 2rem;
            text-align: center;
            font-weight: 600;
            cursor: pointer;
            margin-top: 1rem;
            transition: 0.1s;
        }

        .btn-add-project i {
            margin-right: 8px;
        }

        .btn-add-project:hover {
            background: #ebf3fc;
        }

        /* modal (hidden by default) */
        .modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.3);
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: white;
            border-radius: 2.5rem;
            padding: 2.2rem 2rem;
            width: 90%;
            max-width: 500px;
            box-shadow: 0 30px 50px rgba(0,30,60,0.4);
        }

        .modal-content h3 {
            font-size: 1.6rem;
            margin-bottom: 1.5rem;
            color: #123454;
        }

        .modal-content input, .modal-content textarea, .modal-content select {
            width: 100%;
            padding: 0.9rem 1.2rem;
            margin-bottom: 1rem;
            border: 1px solid #b9cfeb;
            border-radius: 40px;
            font-size: 0.95rem;
            outline: none;
        }

        .modal-content textarea {
            border-radius: 1.5rem;
            resize: vertical;
        }

        .modal-actions {
            display: flex;
            gap: 0.8rem;
            justify-content: flex-end;
            margin-top: 1.5rem;
        }

        .modal-actions button {
            padding: 0.8rem 2rem;
            border: none;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
        }

        .modal-actions .btn-save {
            background: #1e4f8a;
            color: white;
        }

        .modal-actions .btn-cancel {
            background: #e2ecf9;
            color: #1f3b57;
        }

        hr {
            border: 1px solid #dbe8f2;
            margin: 1rem 0;
        }

        .info-note {
            font-size: 0.8rem;
            color: #597b9c;
            margin-top: 0.4rem;
        }

        @media (max-width: 1000px) {
            .dashboard { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
<div class="app-container">
    <!-- top bar (static) -->
    <div class="top-bar">
        <div class="logo">
            <i class="fas fa-cubes"></i> Click Connect
        </div>
        <div class="user-badge">
            <i class="fas fa-circle-user"></i>
            <span><strong>Alex Morgan</strong> (you) · frontend</span>
        </div>
    </div>

    <!-- 3‑column dashboard -->
    <div class="dashboard">
        <!-- COLUMN 1: SEARCH PEOPLE BY SKILL (req #1) -->
        <div class="card">
            <div class="card-header"><i class="fas fa-magnifying-glass"></i> Find by skill</div>
            <div class="search-box">
                <i class="fas fa-search"></i>
                <input type="text" id="skillSearchInput" placeholder="e.g. React, UX, Python" value="React">
                <button id="searchBtn"><i class="fa-regular fa-eye"></i> Search</button>
            </div>
            <div id="searchResults">
                <!-- dynamic results from js -->
                <div class="person-result">
                    <div class="result-avatar">MC</div>
                    <div class="result-info">
                        <h4>Marcus Chen</h4>
                        <div class="result-skills">
                            <span class="mini-skill">React</span>
                            <span class="mini-skill">Python</span>
                            <span class="mini-skill">AWS</span>
                        </div>
                    </div>
                </div>
                <div class="person-result">
                    <div class="result-avatar">TL</div>
                    <div class="result-info">
                        <h4>Tessa Liu</h4>
                        <div class="result-skills">
                            <span class="mini-skill">React</span>
                            <span class="mini-skill">CSS</span>
                            <span class="mini-skill">XD</span>
                        </div>
                    </div>
                </div>
                <div class="info-note" style="padding:0.5rem;">↑ demo results, search updates list</div>
            </div>
        </div>

        <!-- COLUMN 2: MY PROJECTS (req #2) -->
        <div class="card">
            <div class="card-header"><i class="fas fa-briefcase"></i> My projects</div>
            <div id="projectsContainer">
                <!-- filled by JS with sample editable projects -->
            </div>
            <div class="btn-add-project" id="addProjectBtn">
                <i class="fas fa-plus-circle"></i> Add new project
            </div>
        </div>

        <!-- COLUMN 3: MY SKILLS (req #3) + update -->
        <div class="card">
            <div class="card-header"><i class="fas fa-lightbulb"></i> My skills</div>
            <div id="mySkillsContainer" class="my-skills-list">
                <!-- dynamic skill list from js -->
            </div>
            <div class="add-skill-form">
                <input type="text" id="newSkillInput" placeholder="e.g. TypeScript">
                <button id="addSkillBtn"><i class="fas fa-plus"></i> Add</button>
            </div>
            <hr>
            <div><i class="fa-regular fa-pen-to-square" style="margin-right:6px;"></i>Click ✖ to remove a skill</div>
        </div>
    </div>

    <!-- MODAL for adding/editing projects (hidden by default) -->
    <div class="modal" id="projectModal">
        <div class="modal-content">
            <h3 id="modalTitle">Add project</h3>
            <input type="text" id="projectName" placeholder="Project name">
            <input type="text" id="projectRole" placeholder="Your role (e.g. Lead dev)">
            <textarea id="projectDesc" placeholder="Short description" rows="2"></textarea>
            <input type="text" id="projectSkills" placeholder="Skills used (comma separated)">
            <div class="modal-actions">
                <button class="btn-cancel" id="cancelModal">Cancel</button>
                <button class="btn-save" id="saveProject">Save</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        // ---------- FAKE DATA / STATE ----------
        // "My" current user = Alex (we store his skills & projects separately)

        // mySkills (editable)
        let mySkills = ['React', 'Figma', 'UX research', 'CSS'];

        // myProjects (each with id, name, role, description, skills[])
        let myProjects = [
            { id: 'p1', name: 'Dashboard redesign', role: 'UI designer', description: 'Modernized analytics dashboard, improved UX', skills: ['Figma', 'React', 'UserTesting'] },
            { id: 'p2', name: 'Design system migration', role: 'Frontend lead', description: 'Migrated components to new DS with Storybook', skills: ['React', 'CSS', 'Storybook'] }
        ];

        // All employees (for search)
        const employees = [
            { initials: 'JD', name: 'Jessie Du', skills: ['UX research', 'Figma', 'Prototyping', 'React'] },
            { initials: 'MC', name: 'Marcus Chen', skills: ['Python', 'React', 'AWS', 'GraphQL'] },
            { initials: 'SR', name: 'Samira Reed', skills: ['SQL', 'Tableau', 'Jira', 'Analytics'] },
            { initials: 'TL', name: 'Tessa Liu', skills: ['Design system', 'Adobe XD', 'CSS', 'React'] },
            { initials: 'EK', name: 'Emir K.', skills: ['K8s', 'Terraform', 'Azure', 'Python'] },
            { initials: 'AM', name: 'Alex Morgan', skills: mySkills } // yourself
        ];

        // ---------- RENDER HELPERS ----------
        function renderMySkills() {
            const container = document.getElementById('mySkillsContainer');
            container.innerHTML = '';
            mySkills.forEach(skill => {
                const skillDiv = document.createElement('span');
                skillDiv.className = 'skill-item';
                skillDiv.innerHTML = `${skill} <i class="fa-regular fa-circle-xmark" data-skill="${skill}"></i>`;
                container.appendChild(skillDiv);
            });

            // attach remove events to X icons
            document.querySelectorAll('.skill-item i').forEach(icon => {
                icon.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const skillToRemove = icon.dataset.skill;
                    mySkills = mySkills.filter(s => s !== skillToRemove);
                    renderMySkills();
                    // also update search results (Alex's skills changed)
                    renderSearchResults(document.getElementById('skillSearchInput').value);
                });
            });
        }

        function renderProjects() {
            const container = document.getElementById('projectsContainer');
            container.innerHTML = '';
            myProjects.forEach(proj => {
                const projCard = document.createElement('div');
                projCard.className = 'project-card';
                projCard.dataset.id = proj.id;
                projCard.innerHTML = `
                    <div class="project-header">
                        <h4>${proj.name}</h4>
                        <div class="project-actions">
                            <i class="fa-regular fa-pen-to-square" data-id="${proj.id}" data-action="edit"></i>
                            <i class="fa-regular fa-trash-can" data-id="${proj.id}" data-action="delete"></i>
                        </div>
                    </div>
                    <div class="project-meta"><i class="fa-regular fa-user"></i> ${proj.role}</div>
                    <div class="project-desc">${proj.description}</div>
                    <div class="project-skills">
                        ${proj.skills.map(s => `<span class="project-skill-tag">${s}</span>`).join('')}
                    </div>
                `;
                container.appendChild(projCard);
            });

            // Attach edit/delete events
            document.querySelectorAll('.project-actions i[data-action="edit"]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const id = btn.dataset.id;
                    const project = myProjects.find(p => p.id === id);
                    if (project) openProjectModal(project);
                });
            });
            document.querySelectorAll('.project-actions i[data-action="delete"]').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const id = btn.dataset.id;
                    myProjects = myProjects.filter(p => p.id !== id);
                    renderProjects();
                });
            });
        }

        // Search function (req #1)
        function renderSearchResults(query) {
            const container = document.getElementById('searchResults');
            const lowerQuery = query.toLowerCase();
            if (!lowerQuery.trim()) {
                container.innerHTML = '<div class="info-note" style="padding:1rem;">Enter a skill to search</div>';
                return;
            }

            const matching = employees.filter(emp =>
                emp.skills.some(skill => skill.toLowerCase().includes(lowerQuery))
            );

            if (matching.length === 0) {
                container.innerHTML = '<div class="info-note" style="padding:1rem;">No matches</div>';
                return;
            }

            let htmlStr = '';
            matching.forEach(emp => {
                const matchedSkills = emp.skills.filter(s => s.toLowerCase().includes(lowerQuery));
                htmlStr += `
                    <div class="person-result">
                        <div class="result-avatar">${emp.initials}</div>
                        <div class="result-info">
                            <h4>${emp.name}</h4>
                            <div class="result-skills">
                                ${emp.skills.slice(0,4).map(s => `<span class="mini-skill">${s}</span>`).join('')}
                                ${emp.skills.length > 4 ? '<span class="mini-skill">…</span>' : ''}
                            </div>
                        </div>
                    </div>
                `;
            });
            container.innerHTML = htmlStr;
        }

        // Modal logic for projects (add/edit)
        let currentEditId = null;
        const modal = document.getElementById('projectModal');
        const modalTitle = document.getElementById('modalTitle');
        const projName = document.getElementById('projectName');
        const projRole = document.getElementById('projectRole');
        const projDesc = document.getElementById('projectDesc');
        const projSkills = document.getElementById('projectSkills');

        function openProjectModal(project = null) {
            currentEditId = project ? project.id : null;
            modalTitle.textContent = project ? 'Edit project' : 'Add project';
            if (project) {
                projName.value = project.name || '';
                projRole.value = project.role || '';
                projDesc.value = project.description || '';
                projSkills.value = project.skills ? project.skills.join(', ') : '';
            } else {
                projName.value = '';
                projRole.value = '';
                projDesc.value = '';
                projSkills.value = '';
            }
            modal.classList.add('active');
        }

        function closeModal() {
            modal.classList.remove('active');
            currentEditId = null;
        }

        // Save project from modal
        document.getElementById('saveProject').addEventListener('click', () => {
            const name = projName.value.trim();
            const role = projRole.value.trim();
            const desc = projDesc.value.trim();
            const skillsStr = projSkills.value.trim();
            if (!name) return;

            const skillsArray = skillsStr ? skillsStr.split(',').map(s => s.trim()).filter(s => s) : [];

            if (currentEditId) {
                // edit existing
                const index = myProjects.findIndex(p => p.id === currentEditId);
                if (index !== -1) {
                    myProjects[index] = { ...myProjects[index], name, role, description: desc, skills: skillsArray };
                }
            } else {
                // create new with simple id
                const newId = 'p' + Date.now() + Math.random().toString(36).substring(2,6);
                myProjects.push({ id: newId, name, role, description: desc, skills: skillsArray });
            }
            renderProjects();
            closeModal();
        });

        document.getElementById('cancelModal').addEventListener('click', closeModal);
        document.getElementById('addProjectBtn').addEventListener('click', () => openProjectModal());

        // add skill (req #3)
        document.getElementById('addSkillBtn').addEventListener('click', () => {
            const input = document.getElementById('newSkillInput');
            const newSkill = input.value.trim();
            if (newSkill && !mySkills.includes(newSkill)) {
                mySkills.push(newSkill);
                renderMySkills();
                renderSearchResults(document.getElementById('skillSearchInput').value);
                input.value = '';
            }
        });

        // initial search trigger (req #1)
        document.getElementById('searchBtn').addEventListener('click', () => {
            const query = document.getElementById('skillSearchInput').value;
            renderSearchResults(query);
        });

        // also trigger search on page load with default 'React'
        window.addEventListener('load', () => {
            renderMySkills();
            renderProjects();
            renderSearchResults('React'); // default from input
        });

        // extra: pressing Enter in search triggers click
        document.getElementById('skillSearchInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                document.getElementById('searchBtn').click();
            }
        });

        // close modal if click outside (simple)
        window.addEventListener('click', (e) => {
            if (e.target === modal) {
                closeModal();
            }
        });

        // realtime: update search as you type? we'll keep button to match spec
        // but you can also call search on input if desired.
    })();
</script>
<!-- tiny note: meets all three requirements: search, projects add/edit/delete, skills add/remove -->
</body>
</html>
