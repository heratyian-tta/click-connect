<div class="card" style="width: 18rem;">
  <img src="<%= user.profile_image_url %>" class="card-img-top" alt="profile image for <%= user.full_name %>" height="175px" style="object-fit: cover;">
  <div class="card-body">
    <h6 class="card-title text-uppercase" style="color: #e05a2b; font-size: 0.75rem; letter-spacing: 0.08em;"> <%= user.full_name %></h6>
    <p class="card-text" style="font-size: 0.9rem;"><%= user.bio %></p>
  </div>

  <div class="card-body">
    <p style="font-size: 0.8rem; color: #666; margin-bottom: 8px;"><%= user.full_name %>'s Skills:</p>
    <div style="display: flex; flex-wrap: wrap; gap: 6px;">
      <% user.skills.first(5).each do |skill| %>
        <span style="
          background: #f0f4ff;
          color: #3b7ed4;
          border: 1px solid #c5d5f5;
          border-radius: 20px;
          padding: 3px 10px;
          font-size: 0.75rem;
          font-weight: 500;
        "><%= skill.name.titleize %></span>
      <% end %>
      <% if user.skills.count > 5 %>
        <span style="
          background: #f5f5f5;
          color: #888;
          border: 1px solid #ddd;
          border-radius: 20px;
          padding: 3px 10px;
          font-size: 0.75rem;
        ">+ <%= user.skills.count - 5 %> more</span>
      <% end %>
    </div>
  </div>

  <!-- Projects section added here -->
  <div class="card-body">
    <p style="font-size: 0.8rem; color: #666; margin-bottom: 8px;"><%= user.full_name %>'s Projects:</p>
    <div style="display: flex; flex-wrap: wrap; gap: 6px;">
      <% user.projects.first(3).each do |project| %>
        <span style="
          background: #f0fff4;
          color: #2e9e6b;
          border: 1px solid #b2dfcf;
          border-radius: 20px;
          padding: 3px 10px;
          font-size: 0.75rem;
          font-weight: 500;
        "><%= project.title %></span>
      <% end %>
      <% if user.projects.count > 3 %>
        <span style="
          background: #f5f5f5;
          color: #888;
          border: 1px solid #ddd;
          border-radius: 20px;
          padding: 3px 10px;
          font-size: 0.75rem;
        ">+ <%= user.projects.count - 3 %> more</span>
      <% end %>
    </div>
  </div>

  <div class="card-body">
    <%= link_to "View Profile", profile_path(user), class: "card-link" %>
  </div>
</div>
