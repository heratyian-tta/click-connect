<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Click Connect · Connect skilled teammates · internal projects & expertise</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome 6 (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            color: #1a2b3e;
        }

        /* Custom styles on top of Bootstrap */
        .navbar {
            padding: 1.2rem 0;
            background: white;
            box-shadow: 0 2px 20px rgba(0,30,60,0.05);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-size: 1.8rem;
            font-weight: 700;
            color: #0f3b5e;
        }

        .logo i {
            color: #2b6c9e;
            background: #e5f0ff;
            padding: 0.5rem;
            border-radius: 12px;
        }

        .btn-primary-custom {
            background: #1e4f8a;
            color: white;
            border: none;
            padding: 0.7rem 1.8rem;
            border-radius: 40px;
            font-weight: 600;
            transition: 0.2s;
        }

        .btn-primary-custom:hover {
            background: #123f6e;
            color: white;
        }

        .btn-outline-custom {
            background: white;
            color: #1e4f8a;
            border: 2px solid #1e4f8a;
            padding: 0.7rem 1.8rem;
            border-radius: 40px;
            font-weight: 600;
            transition: 0.2s;
        }

        .btn-outline-custom:hover {
            background: #f0f7ff;
            color: #1e4f8a;
        }

        .btn-large {
            padding: 1rem 2.5rem;
            font-size: 1.1rem;
        }

        .hero {
            padding: 4rem 0;
            background: white;
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1.2;
            color: #0a2647;
        }

        .highlight {
            color: #2b6c9e;
            position: relative;
        }

        .highlight::after {
            content: '';
            position: absolute;
            bottom: 5px;
            left: 0;
            width: 100%;
            height: 8px;
            background: rgba(43, 108, 158, 0.2);
            z-index: -1;
        }

        .audience-tag {
            background: #eef4fa;
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            font-size: 0.95rem;
            font-weight: 500;
            color: #1e4f8a;
            border: 1px solid #c5d9f0;
            display: inline-block;
            margin-right: 0.5rem;
            margin-bottom: 0.5rem;
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 800;
            color: #0a2647;
            line-height: 1.2;
        }

        .hero-image {
            background: linear-gradient(145deg, #f0f7ff, #e1eefa);
            border-radius: 30px;
            padding: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15);
            position: relative;
        }

        .floating-card {
            position: absolute;
            background: white;
            padding: 1rem 1.5rem;
            border-radius: 50px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            gap: 1rem;
            bottom: 30px;
            left: -20px;
        }

        .features {
            padding: 6rem 0;
            background: #f8fbfe;
        }

        .feature-card {
            background: white;
            padding: 2.5rem 2rem;
            border-radius: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            transition: 0.3s;
            height: 100%;
        }

        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(30, 79, 138, 0.1);
        }

        .feature-icon {
            background: #e5f0ff;
            width: 60px;
            height: 60px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
        }

        .feature-icon i {
            font-size: 2rem;
            color: #1e4f8a;
        }

        .demo {
            padding: 6rem 0;
        }

        .demo-video {
            background: #1a2b3e;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0,0,0,0.2);
            position: relative;
            cursor: pointer;
        }

        .video-placeholder {
            width: 100%;
            height: 300px;
            background: #2c3e50;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .play-button {
            background: white;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.3s;
        }

        .play-button i {
            color: #1e4f8a;
            font-size: 2rem;
            margin-left: 5px;
        }

        .social-proof {
            padding: 6rem 0;
            background: linear-gradient(135deg, #1e4f8a, #0a2647);
            color: white;
        }

        .testimonial-card {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            padding: 2rem;
            border-radius: 30px;
            border: 1px solid rgba(255,255,255,0.2);
            height: 100%;
        }

        .testimonial-content {
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
            line-height: 1.6;
        }

        .author-avatar {
            width: 50px;
            height: 50px;
            background: #e5f0ff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #1e4f8a;
            font-weight: 700;
            font-size: 1.2rem;
        }

        .media-mentions {
            display: flex;
            justify-content: center;
            gap: 3rem;
            flex-wrap: wrap;
            margin-top: 4rem;
        }

        .media-item {
            opacity: 0.7;
            transition: 0.2s;
            font-size: 1.2rem;
            font-weight: 500;
        }

        .media-item:hover {
            opacity: 1;
        }

        .media-item i {
            margin-right: 0.5rem;
        }

        .cta-section {
            padding: 6rem 0;
            background: white;
            text-align: center;
        }

        .footer {
            background: #f8fbfe;
            padding: 3rem 0;
            border-top: 1px solid #dbe8f2;
        }

        .custom-domain {
            background: #e5f0ff;
            padding: 0.5rem 1.5rem;
            border-radius: 40px;
            color: #1e4f8a;
            font-weight: 500;
            display: inline-block;
        }

        .custom-domain i {
            margin-right: 0.5rem;
        }

        .footer-links a {
            color: #4a6782;
            text-decoration: none;
            margin-left: 2rem;
        }

        .footer-links a:hover {
            color: #1e4f8a;
        }

        /* Modal */
        .modal-content {
            border-radius: 30px;
            padding: 1rem;
        }

        .modal-header {
            border-bottom: none;
            padding-bottom: 0;
        }

        .modal-title {
            font-size: 2rem;
            color: #0a2647;
        }

        .modal-body input {
            width: 100%;
            padding: 1rem 1.2rem;
            margin-bottom: 1rem;
            border: 1px solid #b9cfeb;
            border-radius: 40px;
            font-size: 1rem;
        }

        .btn-modal-cancel {
            background: #e2ecf9;
            color: #1f3b57;
            border: none;
            padding: 0.8rem 2rem;
            border-radius: 40px;
            font-weight: 600;
        }

        .btn-modal-save {
            background: #1e4f8a;
            color: white;
            border: none;
            padding: 0.8rem 2rem;
            border-radius: 40px;
            font-weight: 600;
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2.5rem;
            }
            .footer-links a {
                margin: 0 1rem 0 0;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand logo" href="#">
                <i class="fas fa-cubes"></i> Click Connect
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="#features">Features</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#demo">How it works</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#testimonials">Testimonials</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#pricing">Pricing</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#login">Log in</a>
                    </li>
                    <li class="nav-item ms-lg-3">
                        <button class="btn btn-primary-custom" id="navSignupBtn">Get Started</button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <h1>
                        Find the right teammate<br>
                        <span class="highlight">before you build</span>
                    </h1>
                    <p class="fs-5 text-secondary mb-4">
                        Click Connect helps you discover colleagues with the exact skills you need for your next project. No more guessing who knows what.
                    </p>
                    
                    <!-- Audience Targeting -->
                    <div class="mb-4">
                        <span class="audience-tag"><i class="fas fa-code"></i> Developers</span>
                        <span class="audience-tag"><i class="fas fa-paint-brush"></i> Designers</span>
                        <span class="audience-tag"><i class="fas fa-chart-line"></i> PMs</span>
                        <span class="audience-tag"><i class="fas fa-database"></i> Data teams</span>
                        <span class="audience-tag"><i class="fas fa-bullhorn"></i> Marketing</span>
                    </div>

                    <!-- Clear CTA -->
                    <div class="d-flex gap-3 flex-wrap mb-5">
                        <button class="btn btn-primary-custom btn-large" id="heroSignupBtn">
                            <i class="fas fa-rocket me-2"></i>Start connecting free
                        </button>
                        <button class="btn btn-outline-custom btn-large" id="demoBtn">
